{% extends 'base.html.twig' %}

{% block title %}Mon compte{% endblock %}

{% block body %}
    <h1>Mon Profil</h1>

    <h3 class="my-3">Bienvenue {{ user.nickname }}</h3>

    <div>
        <h2 class="mb-3">Mes Informations</h2>

        <div class="container">
            <div class="col-12 mb-3">
                <div class="row">
                    <div class="col-2 mb-2 font-weight-bold">Courriel</div>
                    <div class="col-2">{{ user.email }}</div>
                </div>
                <div class="row">
                    <div class="col-2 mb-2 font-weight-bold">Pseudo</div>
                    <div class="col-2">{{ user.nickname }}</div>
                </div>
            </div>

            <div class="col-12 mb-3">
                <div class="row">
                    <div class="col ml-3 mb-2">Ma Biographie</div>
                </div>
                <div class="row">
                    <div class="col border rounded p-3 w-50 bg-light">{{ user.bio }}</div>
                </div>
            </div>

            <div class="col-12">
                <div class="row">
                    <div class="col-6">
                        <h3>Modifier votre Email</h3>

                        {{ form_start(emailForm) }}
                            {{ form_row(emailForm.email) }}
                            <button type="submit" class="btn btn-success mt-3">Mettre à jour mon courriel</button>
                        {{ form_end(emailForm) }}
                    </div>

                    <div class="col-6">
                        <h3>Modifier votre mot de passe</h3>

                        {{ form_start(passwordForm) }}
                            {{ form_row(passwordForm.oldPassword, {'id': 'password-field'}) }}
                            <hr>
                            {{ form_row(passwordForm.plainPassword) }}
                            <button type="submit" class="btn btn-success mt-3">Mettre à jour mon mot de passe</button>
                        {{ form_end(passwordForm) }}
                    </div>
                </div>
            </div>
        </div>
    </div>

<div class="container">
<div class="row">
  <div class="col-md-8 col-md-offset-2">

    <div class="panel panel-default">
      <div class="panel-body">
        <form class="form-horizontal" method="" action="">

          <div class="form-group">
            <label class="col-md-4 control-label">Email</label>
            <div class="col-md-6">
              <input type="email" class="form-control" name="email" value="">
            </div>
          </div>
          <div class="form-group">
            <label class="col-md-4 control-label">Password</label>
            <div class="col-md-6">
              <input id="password-field" type="password" class="form-control" name="password" value="secret">
              <span toggle="#password-field" class="fa fa-fw fa-eye field-icon toggle-password"></span>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
</div>
{% endblock %}

{% block javascripts_loaded %}

    <style>
.field-icon {
  float: right;
  margin-left: -25px;
  margin-top: -25px;
  position: relative;
  z-index: 2;
}

.container{
  padding-top:50px;
  margin: auto;
}
    </style>
    <script>

$(".toggle-password").click(function() {

  $(this).toggleClass("fa-eye fa-eye-slash");
  var input = $($(this).attr("toggle"));
  if (input.attr("type") == "password") {
    input.attr("type", "text");
  } else {
    input.attr("type", "password");
  }
});
    </script>
{% endblock %}